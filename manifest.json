{
    "manifest_version": 3,
    "name": "Save Link Extension",
    "version": "1.0.0",
    "description": "Lưu và quản lý links với tên và mô tả",
    "permissions": [
        "storage",
        "tabs",
        "contextMenus",
        "notifications",
        "identity"
    ],
    "host_permissions": [
        "https://www.googleapis.com/*",
        "https://firestore.googleapis.com/*",
        "https://www.gstatic.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "key": ""
}